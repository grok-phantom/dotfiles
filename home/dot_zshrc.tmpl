# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# If you come from bash you might have to change your $PATH.
{{- $paths := list }}
{{- $homeDir := .chezmoi.homeDir }}
{{- range $_, $relPath := list "bin" "go/bin" ".cargo/bin" ".local/bin" }}
{{    $path := joinPath $homeDir $relPath }}
{{-   if stat $path }}
{{-     $paths = mustAppend $paths $path }}
{{-   end }}
{{- end }}
{{- if $paths }}
export PATH={{ toStrings $paths | join ":" }}:$PATH
{{- end }}

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load --- if set to "random", it will
# load a random theme each time oh-my-zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="powerlevel10k/powerlevel10k"

# Uncomment one of the following lines to change the auto-update behavior
zstyle ':omz:update' mode disabled  # disable automatic updates

# Uncomment the following line if you want to disable marking untracked files
# under VCS as dirty. This makes repository status check for large repositories
# much, much faster.
# DISABLE_UNTRACKED_FILES_DIRTY="true"
HIST_STAMPS="yyyy-mm-dd"

# Would you like to use another custom folder than $ZSH/custom?
# ZSH_CUSTOM=/path/to/new-custom-folder

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
{{- $plugins := list
  "git"
  "eza"
  "extract"
  "zsh-vi-mode"
  "fast-syntax-highlighting"
  "zsh-autosuggestions"
  "command-not-found"
  "aliases"
  "history"
  "tldr"
  "tmux"
}}
{{- if lookPath "docker" }}
{{-   $plugins = mustAppend $plugins "docker" }}
{{- end }}
{{- if lookPath "rsync" }}
{{-   $plugins = mustAppend $plugins "rsync" }}
{{- end }}
{{- if lookPath "uv" }}
{{-   $plugins = mustAppend $plugins "uv" }}
{{- end }}
{{- if eq .chezmoi.os "linux" }}
{{-   $plugins = mustAppend $plugins "systemd" }}
{{- end }}
plugins=(
{{- range $plugins }}
  {{ . }}
{{- end }}

)


if [[ -s "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# User configuration

{{- if lookPath "bat" }}
alias cat=bat
{{- else if lookPath "batcat" }}
alias cat=batcat
{{- end }}
{{- if lookPath "eza" }}
alias ls='eza'
alias ll='eza -lah'
{{- end }}
{{- if lookPath "fdfind" }}
alias fd=fdfind
{{- end }}
{{- if lookPath "zoxide" }}
eval "$(zoxide init zsh)"
{{- end }}
if command -v yazi >/dev/null 2>&1; then
  y() {
    local tmp cwd
    tmp="$(mktemp "${TMPDIR:-/tmp}/yazi-cwd.XXXXXX")" || return
    command yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp" 2>/dev/null)" && [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
      builtin cd -- "$cwd"
    fi
    command rm -f -- "$tmp"
  }
  alias yy='y'
  alias r='y'
  alias ranger='y'
fi

{{- $proxyHost := "127.0.0.1" }}
{{- $proxyHttpPort := "7890" }}
{{- $proxySocksPort := "7890" }}
{{- if eq .chezmoi.os "darwin" }}
{{-   $proxyHttpPort = "6152" }}
{{-   $proxySocksPort = "6153" }}
{{- end }}
{{- if hasKey . "proxy_host" }}
{{-   $proxyHost = .proxy_host }}
{{- end }}
{{- if hasKey . "proxy_http_port" }}
{{-   $proxyHttpPort = .proxy_http_port }}
{{- end }}
{{- if hasKey . "proxy_socks_port" }}
{{-   $proxySocksPort = .proxy_socks_port }}
{{- end }}
{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") }}
proxy_host={{ $proxyHost | quote }}
proxy_http_url="http://${proxy_host}:{{ $proxyHttpPort }}"
proxy_socks_url="socks5://${proxy_host}:{{ $proxySocksPort }}"
alias proxyon='export http_proxy="$proxy_http_url"; export https_proxy="$proxy_http_url"; export all_proxy="$proxy_socks_url"'
{{- if eq .chezmoi.os "darwin" }}
if command -v brew >/dev/null 2>&1; then
  brew() {
    http_proxy="$proxy_http_url" \
      https_proxy="$proxy_http_url" \
      all_proxy="$proxy_socks_url" \
      command brew "$@"
  }
fi
{{- end }}
{{- end }}
alias proxyoff='unset http_proxy https_proxy all_proxy'


miniforge_dir="$HOME/opt/miniforge3"
if [[ -x "$miniforge_dir/bin/conda" ]]; then
  __conda_setup="$("$miniforge_dir/bin/conda" shell.zsh hook 2>/dev/null)"
  if [[ $? -eq 0 ]]; then
    eval "$__conda_setup"
  elif [[ -f "$miniforge_dir/etc/profile.d/conda.sh" ]]; then
    source "$miniforge_dir/etc/profile.d/conda.sh"
  else
    export PATH="$miniforge_dir/bin:$PATH"
  fi
  unset __conda_setup
fi
unset miniforge_dir

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export EDITOR='vim'
export VISUAL=$EDITOR

if [[ -d /usr/local/cuda/bin ]]; then
  export PATH=/usr/local/cuda/bin:$PATH
fi

if [[ "$TERM_PROGRAM" == "vscode" ]] && command -v code >/dev/null 2>&1; then
  shell_integration="$(code --locate-shell-integration-path zsh 2>/dev/null)"
  [[ -r "$shell_integration" ]] && source "$shell_integration"
  unset shell_integration
fi

if [[ "$TERM_PROGRAM" == "iTerm.app" ]]; then
  iterm2_integration="$HOME/.iterm2_shell_integration.zsh"
  [[ -r "$iterm2_integration" ]] && source "$iterm2_integration"
  unset iterm2_integration
fi
{{- /* vim: set filetype=zsh: */}}
