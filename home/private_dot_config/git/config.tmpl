[user]
	name = Lei Chen
	email = {{ .email }}
[core]
	autocrlf = input
	pager = less -FX
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[diff]
	colorMoved = default
[alias]
	st = status
	co = checkout
	lg = log --oneline --graph --decorate --all
{{- if not .ephemeral }}
[url "git@github.com:grok-phantom/"]
	insteadOf = https://github.com/grok-phantom/
{{- end -}}
{{/* vim: set filetype=gitconfig: */}}
